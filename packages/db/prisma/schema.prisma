datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum MessageDirection {
  inbound
  outbound

  @@map("message_direction")
}

enum PostStatus {
  draft
  scheduled
  published
  failed

  @@map("post_status")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String?
  stripeCustomerId   String?  @map("stripe_customer_id")
  subscriptionStatus String?  @map("subscription_status")
  createdAt          DateTime @default(now()) @map("created_at")
  planId             String?  @map("plan_id")

  plan        Plan?        @relation(fields: [planId], references: [id])
  accounts    Account[]
  automations Automation[]
  notifications Notification[]

  @@map("user")
}

model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  price        Int
  messageLimit Int?     @map("message_limit")
  createdAt    DateTime @default(now()) @map("created_at")

  users User[]

  @@map("plan")
}

model Account {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  platform     String
  name         String?
  externalId   String   @map("external_id")
  accessToken  String?  @map("access_token")
  refreshToken String?  @map("refresh_token")
  tokenValid   Boolean  @default(true) @map("token_valid")
  lastChecked  DateTime? @map("last_checked")
  createdAt    DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  threads  Thread[]
  posts    Post[]

  @@unique([platform, externalId])
  @@index([userId])
  @@map("account")
}


model Automation {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  triggers   Trigger[]
  actions    Action[]
  executions AutomationExecution[]

  @@index([userId])
  @@map("automation")
}


model Trigger {
  id           String     @id @default(cuid())
  automationId String     @map("automation_id")
  type         String
  keywords     String[]
  metadata     Json?

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@map("trigger")
}


model Action {
  id           String     @id @default(cuid())
  automationId String     @map("automation_id")
  type         String
  payload      Json?

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@map("action")
}


model Thread {
  id               String   @id @default(cuid())
  accountId        String   @map("account_id")
  externalThreadId String   @map("external_thread_id")
  createdAt        DateTime @default(now()) @map("created_at")

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([accountId, externalThreadId])
  @@index([accountId])
  @@map("thread")
}


model Message {
  id           String           @id @default(cuid())
  accountId    String           @map("account_id")
  threadId     String           @map("thread_id")
  externalId   String           @unique @map("external_id")
  direction    MessageDirection
  content      String
  createdAt    DateTime         @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  thread  Thread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  automationExecutions AutomationExecution[]

  @@index([threadId, createdAt])
  @@map("message")
}


model Post {
  id          String     @id @default(cuid())
  accountId   String     @map("account_id")
  content     String
  mediaUrl    String?    @map("media_url")
  scheduledAt DateTime?  @map("scheduled_at")
  status      PostStatus
  createdAt   DateTime   @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("post")
}


model AutomationExecution {
  id           String   @id @default(cuid())
  automationId String   @map("automation_id")
  messageId    String?  @map("message_id")
  createdAt    DateTime @default(now()) @map("created_at")

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  message    Message?   @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([automationId])
  @@map("automation_execution")
}

enum WorkerStatus {
  COMPLETED
  FAILED
  RETRY

  @@map("worker_status")
}

model WorkerLog {
  id         String       @id @default(cuid())
  jobId      String       @map("job_id")
  queueName  String       @map("queue_name")
  status     WorkerStatus
  error      String?
  attempts   Int          @default(0)
  durationMs Int?         @map("duration_ms")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@index([jobId])
  @@index([createdAt])
  @@map("worker_log")
}

enum NotificationType {
  TOKEN_INVALID
  SYSTEM_ERROR
  USAGE_LIMIT

  @@map("notification_type")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notification")
}

